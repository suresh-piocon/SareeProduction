@page "/yarn-stock"
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Navigation

<PageTitle>Yarn & Stock - Saree Production</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="my-4">
    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-4">
        <!-- TAB 1: YARN STOCK LEVELS -->
        <MudTabPanel Text="Yarn Stock Levels" Icon="@Icons.Material.Filled.Inventory">
            <div class="d-flex align-center justify-space-between mb-4">
                <div>
                    <MudText Typo="Typo.h5" Color="Color.Primary"><b>Yarn Stock Management</b></MudText>
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Monitor, edit, and reset yarn inventory quantities</MudText>
                </div>
                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddStockDialog">
                        Add Stock
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteSweep" OnClick="ConfirmDeleteAllStock">
                        Delete All
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.ExitToApp" OnClick="ExitToDashboard">
                        Exit
                    </MudButton>
                </div>
            </div>

            <MudTable Items="_stockList" Loading="_loadingStock" Elevation="0">
                <HeaderContent>
                    <MudTh>Yarn Type</MudTh>
                    <MudTh>Color</MudTh>
                    <MudTh>Denier</MudTh>
                    <MudTh>Current Qty</MudTh>
                    <MudTh>Current Weight (kg)</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Yarn Type"><b>@context.Yarn?.YarnType</b></MudTd>
                    <MudTd DataLabel="Color">@(context.Yarn?.Color ?? "-")</MudTd>
                    <MudTd DataLabel="Denier">@(context.Yarn?.Denier ?? "-")</MudTd>
                    <MudTd DataLabel="Current Qty">
                        <b>@context.Qty.ToString("F3")</b>
                    </MudTd>
                    <MudTd DataLabel="Current Weight">
                        <MudText Color="@(context.Quantity < 5.000m ? Color.Error : Color.Default)">
                            <b>@context.Quantity.ToString("F3") kg</b>
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.Quantity < 5.000m)
                        {
                            <MudChip T="string" Color="Color.Error" Size="Size.Small" Icon="@Icons.Material.Filled.Warning">Low Stock</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.CheckCircle">In Stock</MudChip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => OpenEditStockDialog(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => ConfirmDeleteStock(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudTabPanel>

        <!-- TAB 2: YARN CATALOG MASTER -->
        <MudTabPanel Text="Yarn Catalog Master" Icon="@Icons.Material.Filled.List">
            <div class="d-flex align-center justify-space-between mb-4">
                <div>
                    <MudText Typo="Typo.h5" Color="Color.Primary"><b>Yarn Master Catalog</b></MudText>
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Create and manage different yarn types (Silk, Zari, Cotton)</MudText>
                </div>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
                    Add Yarn Type
                </MudButton>
            </div>

            <MudTable Items="_yarns" Filter="new Func<YarnMaster,bool>(FilterYarnFunc)" @bind-SelectedItem="_selectedYarn" Loading="_loadingYarn" Elevation="0">
                <ToolBarContent>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchYarnString" Placeholder="Search yarn..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Immediate="true"></MudTextField>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>Yarn Type</MudTh>
                    <MudTh>Color</MudTh>
                    <MudTh>Denier (Thickness)</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Yarn Type"><b>@context.YarnType</b></MudTd>
                    <MudTd DataLabel="Color">@(context.Color ?? "-")</MudTd>
                    <MudTd DataLabel="Denier">@(context.Denier ?? "-")</MudTd>
                    <MudTd DataLabel="Description">@(context.Description ?? "-")</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" Size="Size.Small" OnClick="@(() => OpenEditDialog(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => ConfirmDeleteYarn(context))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudTabPanel>

        <!-- TAB 3: YARN CATEGORIES -->
        <MudTabPanel Text="Yarn Categories" Icon="@Icons.Material.Filled.Category">
            <div class="d-flex align-center justify-space-between mb-4">
                <div>
                    <MudText Typo="Typo.h5" Color="Color.Primary"><b>Yarn Categories</b></MudText>
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Add and manage yarn category master choices (e.g. Warp, Weft, Jari)</MudText>
                </div>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCategoryCreateDialog">
                    Add Category
                </MudButton>
            </div>

            <MudTable Items="_categories" Loading="_loadingCategory" Elevation="0">
                <HeaderContent>
                    <MudTh>Category Name</MudTh>
                    <MudTh>Created At</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Category Name"><b>@context.Name</b></MudTd>
                    <MudTd DataLabel="Created At">@context.CreatedAt.ToLocalTime().ToString("g")</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" Size="Size.Small" OnClick="@(() => OpenCategoryEditDialog(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => ConfirmDeleteCategory(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudTabPanel>
    </MudTabs>
</MudContainer>

<!-- Create/Edit Yarn Dialog -->
<MudDialog @bind-Visible="_isYarnFormOpen" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(_editYarnModel.Id == Guid.Empty ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)" Class="mr-2" />
            @(_editYarnModel.Id == Guid.Empty ? "Add New Yarn Type" : "Edit Yarn Type")
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="@_editYarnModel" OnValidSubmit="SaveYarn">
            <DataAnnotationsValidator />
            <MudGrid>
                <MudItem xs="12">
                    <MudSelect T="string" Label="Yarn Category" @bind-Value="_editYarnModel.YarnType" Required="true" Variant="Variant.Outlined">
                        @foreach (var category in _categories)
                        {
                            <MudSelectItem Value="@category.Name">@category.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Label="Color / Code" @bind-Value="_editYarnModel.Color" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Label="Denier (e.g. 16/18 Denier)" @bind-Value="_editYarnModel.Denier" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Label="Description / Notes" @bind-Value="_editYarnModel.Description" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                @if (_editYarnModel.Id == Guid.Empty)
                {
                    <MudItem xs="12" sm="6">
                        <MudNumericField Label="Initial Qty (Count)" @bind-Value="_initialStockQty" Format="F3" Min="0.000m" HelperText="Starting count (cones/bags)" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField Label="Initial Weight (kg)" @bind-Value="_initialStockWeight" Format="F3" Min="0.000m" HelperText="Starting weight in kg" Variant="Variant.Outlined" />
                    </MudItem>
                }
            </MudGrid>
            <div class="d-flex justify-end mt-6">
                <MudButton OnClick="CloseYarnDialog" Class="mr-2">Cancel</MudButton>
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">Save</MudButton>
            </div>
        </EditForm>
    </DialogContent>
</MudDialog>

<!-- Add/Edit Stock Dialog -->
<MudDialog @bind-Visible="_isStockFormOpen" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(_editStockModel.Id == Guid.Empty ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)" Class="mr-2" />
            @(_editStockModel.Id == Guid.Empty ? "Add Yarn Stock" : "Edit Yarn Stock")
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="@_editStockModel" OnValidSubmit="SaveStock">
            <DataAnnotationsValidator />
            <MudGrid>
                @if (_editStockModel.Id == Guid.Empty)
                {
                    <MudItem xs="12">
                        <MudSelect T="Guid" Label="Select Yarn" @bind-Value="_editStockModel.YarnId" Required="true" Variant="Variant.Outlined">
                            @foreach (var yarn in _yarns)
                            {
                                <MudSelectItem Value="@yarn.Id">@yarn.YarnType (@yarn.Color) - @yarn.Denier</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                }
                else
                {
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle1">Yarn Type: <b>@_editStockModel.Yarn?.YarnType (@_editStockModel.Yarn?.Color)</b></MudText>
                    </MudItem>
                }
                <MudItem xs="12" sm="6">
                    <MudNumericField Label="Qty (Count)" @bind-Value="_editStockModel.Qty" Format="F3" Min="0.000m" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField Label="Weight (kg)" @bind-Value="_editStockModel.Quantity" Format="F3" Min="0.000m" Required="true" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
            <div class="d-flex justify-end mt-6">
                <MudButton OnClick="CloseStockDialog" Class="mr-2">Cancel</MudButton>
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">Save</MudButton>
            </div>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    private List<YarnMaster> _yarns = new();
    private List<SareeProductionApp.Client.Models.YarnStock> _stockList = new();
    private YarnMaster _selectedYarn = new();
    private YarnMaster _editYarnModel = new();
    private SareeProductionApp.Client.Models.YarnStock _adjustStockModel = new();

    private string _searchYarnString = "";
    private bool _loadingYarn = true;
    private bool _loadingStock = true;
    private bool _isYarnFormOpen = false;
    private bool _isStockFormOpen = false;
    private SareeProductionApp.Client.Models.YarnStock _editStockModel = new();
    private decimal _initialStockQty = 0.000m;
    private decimal _initialStockWeight = 0.000m;

    private List<YarnCategory> _categories = new();
    private YarnCategory _editCategoryModel = new();
    private bool _loadingCategory = true;
    private bool _isCategoryFormOpen = false;

    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };

    protected override async Task OnInitializedAsync()
    {
        await LoadYarns();
        await LoadStock();
        await LoadCategories();
    }

    private async Task LoadYarns()
    {
        _loadingYarn = true;
        try
        {
            _yarns = await Http.GetFromJsonAsync<List<YarnMaster>>("api/Yarn") ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error loading yarns: " + ex.Message, Severity.Error);
        }
        finally
        {
            _loadingYarn = false;
        }
    }

    private async Task LoadStock()
    {
        _loadingStock = true;
        try
        {
            _stockList = await Http.GetFromJsonAsync<List<SareeProductionApp.Client.Models.YarnStock>>("api/Yarn/stock") ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error loading stock: " + ex.Message, Severity.Error);
        }
        finally
        {
            _loadingStock = false;
        }
    }

    private bool FilterYarnFunc(YarnMaster yarn)
    {
        if (string.IsNullOrWhiteSpace(_searchYarnString)) return true;
        if (yarn.YarnType.Contains(_searchYarnString, StringComparison.OrdinalIgnoreCase)) return true;
        if (yarn.Color?.Contains(_searchYarnString, StringComparison.OrdinalIgnoreCase) ?? false) return true;
        if (yarn.Denier?.Contains(_searchYarnString, StringComparison.OrdinalIgnoreCase) ?? false) return true;
        return false;
    }

    private void OpenCreateDialog()
    {
        _editYarnModel = new YarnMaster { Id = Guid.Empty };
        _initialStockQty = 0.000m;
        _initialStockWeight = 0.000m;
        _isYarnFormOpen = true;
    }

    private void OpenEditDialog(YarnMaster yarn)
    {
        _editYarnModel = new YarnMaster
        {
            Id = yarn.Id,
            YarnType = yarn.YarnType,
            Color = yarn.Color,
            Denier = yarn.Denier,
            Description = yarn.Description
        };
        _isYarnFormOpen = true;
    }

    private void CloseYarnDialog()
    {
        _isYarnFormOpen = false;
    }

    private async Task SaveYarn()
    {
        try
        {
            if (_editYarnModel.Id == Guid.Empty)
            {
                var response = await Http.PostAsJsonAsync("api/Yarn", _editYarnModel);
                if (response.IsSuccessStatusCode)
                {
                    var createdYarn = await response.Content.ReadFromJsonAsync<YarnMaster>();
                    if (createdYarn != null && (_initialStockQty > 0.000m || _initialStockWeight > 0.000m))
                    {
                        await Http.PostAsync($"api/Yarn/stock/adjust?yarnId={createdYarn.Id}&quantity={_initialStockWeight}&qty={_initialStockQty}", null);
                    }
                    Snackbar.Add("Yarn type created successfully!", Severity.Success);
                }
            }
            else
            {
                var response = await Http.PutAsJsonAsync($"api/Yarn/{_editYarnModel.Id}", _editYarnModel);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Yarn type updated successfully!", Severity.Success);
                }
            }
            _isYarnFormOpen = false;
            await LoadYarns();
            await LoadStock();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error saving yarn: " + ex.Message, Severity.Error);
        }
    }

    private async Task ConfirmDeleteYarn(YarnMaster yarn)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Warning", 
            $"Are you sure you want to delete yarn type '{yarn.YarnType} ({yarn.Color})'? This will also delete its stock data.", 
            yesText: "Delete", cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                var response = await Http.DeleteAsync($"api/Yarn/{yarn.Id}");
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Yarn type deleted successfully!", Severity.Success);
                    await LoadYarns();
                    await LoadStock();
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add("Error deleting yarn type: " + ex.Message, Severity.Error);
            }
        }
    }

    private void OpenAddStockDialog()
    {
        _editStockModel = new SareeProductionApp.Client.Models.YarnStock { Id = Guid.Empty };
        _isStockFormOpen = true;
    }

    private void OpenEditStockDialog(SareeProductionApp.Client.Models.YarnStock stock)
    {
        _editStockModel = new SareeProductionApp.Client.Models.YarnStock
        {
            Id = stock.Id,
            YarnId = stock.YarnId,
            Yarn = stock.Yarn,
            Qty = stock.Qty,
            Quantity = stock.Quantity,
            CreatedAt = stock.CreatedAt
        };
        _isStockFormOpen = true;
    }

    private void CloseStockDialog()
    {
        _isStockFormOpen = false;
    }

    private async Task SaveStock()
    {
        try
        {
            if (_editStockModel.Id == Guid.Empty)
            {
                var existing = _stockList.FirstOrDefault(s => s.YarnId == _editStockModel.YarnId);
                if (existing != null)
                {
                    existing.Qty = _editStockModel.Qty;
                    existing.Quantity = _editStockModel.Quantity;
                    var response = await Http.PutAsJsonAsync($"api/Yarn/stock/{existing.Id}", existing);
                    if (response.IsSuccessStatusCode)
                    {
                        Snackbar.Add("Stock updated successfully!", Severity.Success);
                    }
                }
                else
                {
                    var response = await Http.PostAsync($"api/Yarn/stock/adjust?yarnId={_editStockModel.YarnId}&quantity={_editStockModel.Quantity}&qty={_editStockModel.Qty}", null);
                    if (response.IsSuccessStatusCode)
                    {
                        Snackbar.Add("Stock created successfully!", Severity.Success);
                    }
                }
            }
            else
            {
                var response = await Http.PutAsJsonAsync($"api/Yarn/stock/{_editStockModel.Id}", _editStockModel);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Stock updated successfully!", Severity.Success);
                }
            }
            _isStockFormOpen = false;
            await LoadStock();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error saving stock: " + ex.Message, Severity.Error);
        }
    }

    private async Task ConfirmDeleteStock(SareeProductionApp.Client.Models.YarnStock stock)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Warning", 
            $"Are you sure you want to reset the stock of yarn '{stock.Yarn?.YarnType} ({stock.Yarn?.Color})' to 0?", 
            yesText: "Delete / Reset", cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                stock.Qty = 0.000m;
                stock.Quantity = 0.000m;
                var response = await Http.PutAsJsonAsync($"api/Yarn/stock/{stock.Id}", stock);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Stock reset to 0 successfully!", Severity.Success);
                    await LoadStock();
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add("Error resetting stock: " + ex.Message, Severity.Error);
            }
        }
    }

    private async Task ConfirmDeleteAllStock()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Warning", 
            "Are you sure you want to delete and reset ALL yarn stock levels to 0? This cannot be undone.", 
            yesText: "Reset All", cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                var response = await Http.PostAsync("api/Yarn/stock/reset-all", null);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("All stock levels reset to 0 successfully!", Severity.Success);
                    await LoadStock();
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add("Error resetting all stock: " + ex.Message, Severity.Error);
            }
        }
    }

    private void ExitToDashboard()
    {
        Navigation.NavigateTo("/");
    }

    private async Task LoadCategories()
    {
        _loadingCategory = true;
        try
        {
            _categories = await Http.GetFromJsonAsync<List<YarnCategory>>("api/YarnCategory") ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error loading categories: " + ex.Message, Severity.Error);
        }
        finally
        {
            _loadingCategory = false;
        }
    }

    private void OpenCategoryCreateDialog()
    {
        _editCategoryModel = new YarnCategory { Id = Guid.Empty };
        _isCategoryFormOpen = true;
    }

    private void OpenCategoryEditDialog(YarnCategory category)
    {
        _editCategoryModel = new YarnCategory
        {
            Id = category.Id,
            Name = category.Name,
            CreatedAt = category.CreatedAt
        };
        _isCategoryFormOpen = true;
    }

    private void CloseCategoryDialog()
    {
        _isCategoryFormOpen = false;
    }

    private async Task SaveCategory()
    {
        try
        {
            if (_editCategoryModel.Id == Guid.Empty)
            {
                var response = await Http.PostAsJsonAsync("api/YarnCategory", _editCategoryModel);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Category created successfully!", Severity.Success);
                }
            }
            else
            {
                var response = await Http.PutAsJsonAsync($"api/YarnCategory/{_editCategoryModel.Id}", _editCategoryModel);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Category updated successfully!", Severity.Success);
                }
            }
            _isCategoryFormOpen = false;
            await LoadCategories();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error saving category: " + ex.Message, Severity.Error);
        }
    }

    private async Task ConfirmDeleteCategory(YarnCategory category)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Warning", 
            $"Are you sure you want to delete category '{category.Name}'? Existing yarns using this category will remain unchanged.", 
            yesText: "Delete", cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                var response = await Http.DeleteAsync($"api/YarnCategory/{category.Id}");
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Category deleted successfully!", Severity.Success);
                    await LoadCategories();
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add("Error deleting category: " + ex.Message, Severity.Error);
            }
        }
    }
}
